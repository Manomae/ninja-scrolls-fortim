rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User GIFs
    match /users/{userId}/gifs/{gifId} {
      function isValidGif(data) {
        return data.keys().hasAll(['id', 'url', 'title', 'userId', 'createdAt']) &&
               data.keys().size() == 5 &&
               data.id is string && data.id.size() <= 256 &&
               data.url is string && data.url.size() <= 2048 &&
               data.title is string && data.title.size() <= 256 &&
               data.userId == request.auth.uid &&
               data.createdAt == request.time;
      }

      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(gifId) && 
                      isValidGif(request.resource.data);
      
      allow delete: if isOwner(userId);
    }
  }
}
