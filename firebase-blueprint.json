{
  "entities": {
    "UserGif": {
      "title": "User GIF",
      "description": "A GIF saved by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "url", "title", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/gifs/{gifId}": {
      "schema": "UserGif",
      "description": "Collection of GIFs for a specific user"
    }
  }
}
